{
  "compilerOptions": {
    "target": "ES2022",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@secuai/shared": [
        "packages/shared/src"
      ],
      "@secuai/shared/*": [
        "packages/shared/src/*"
      ]
    },
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  }
}

