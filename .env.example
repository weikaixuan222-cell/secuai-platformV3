# Docker 基础设施
POSTGRES_PORT=55432
REDIS_PORT=6379

# API 监听
# 直接调试或需要局域网访问时可设为 0.0.0.0
# Ubuntu 生产部署配合 Nginx 反向代理时，建议改为 127.0.0.1
HOST=0.0.0.0
API_PORT=3201

# Web 监听
# 直接调试或需要局域网访问时可设为 0.0.0.0
# Ubuntu 生产部署配合 Nginx 反向代理时，建议改为 127.0.0.1
HOSTNAME=0.0.0.0
WEB_PORT=3200

# 内部服务地址
DATABASE_URL=postgresql://secuai:secuai_dev_password@127.0.0.1:55432/secuai
DB_SSL_MODE=disable
API_URL=http://127.0.0.1:3201
AI_ANALYZER_URL=http://127.0.0.1:8000
AI_ANALYZER_TIMEOUT_MS=1500
AI_ANALYZER_MAX_RETRIES=1
