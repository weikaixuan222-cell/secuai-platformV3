# =========================
# 基础设施端口
# =========================

# PostgreSQL 宿主机映射端口
# 如宿主机已有 PostgreSQL 占用，可改成其他端口，并同步修改 DATABASE_URL
POSTGRES_PORT=55432

# Redis 宿主机映射端口
REDIS_PORT=6379

# =========================
# API 监听
# =========================

# API 监听地址
# 本地开发 / 局域网联调可用 0.0.0.0
# Ubuntu 生产部署配合 Nginx 时建议改为 127.0.0.1
HOST=0.0.0.0

# API 固定内部端口
API_PORT=3201

# =========================
# Web 监听
# =========================

# Web 监听地址
# 本地开发 / 局域网联调可用 0.0.0.0
# Ubuntu 生产部署配合 Nginx 时建议改为 127.0.0.1
HOSTNAME=0.0.0.0

# Web 固定内部端口
WEB_PORT=3200

# =========================
# 内部服务地址
# =========================

# API 连接 PostgreSQL 的地址
# 需与 POSTGRES_PORT 保持一致
DATABASE_URL=postgresql://secuai:secuai_dev_password@127.0.0.1:55432/secuai

# 当前默认不启用数据库 SSL
DB_SSL_MODE=disable

# Web 请求 API 使用的内部地址
API_URL=http://127.0.0.1:3201

# AI analyzer 地址
# 当前标准生产入口不会自动启动 analyzer
AI_ANALYZER_URL=http://127.0.0.1:8000
AI_ANALYZER_TIMEOUT_MS=1500
AI_ANALYZER_MAX_RETRIES=1
