{
  "name": "secuai-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:demo-stack": "node scripts/start-demo-stack.mjs",
    "smoke:demo-stack-ready": "node scripts/demo-stack-ready-smoke.mjs",
    "doctor:demo-stack": "node scripts/demo-stack-doctor.mjs",
    "demo:standard": "node scripts/demo-standard-flow.mjs",
    "prod:prepare": "node scripts/prepare-production-stack.mjs",
    "prod:start": "pm2 start deploy/pm2/ecosystem.config.cjs",
    "prod:restart": "pm2 restart deploy/pm2/ecosystem.config.cjs --update-env",
    "prod:stop": "pm2 delete deploy/pm2/ecosystem.config.cjs",
    "prod:logs": "pm2 logs",
    "doctor:prod": "node scripts/production-stack-doctor.mjs",
    "dev:web": "npm run dev --workspace @secuai/web",
    "dev:api": "npm run dev --workspace @secuai/api",
    "build:web": "npm run build --workspace @secuai/web",
    "build:api": "npm run build --workspace @secuai/api",
    "test:api": "npm run test --workspace @secuai/api"
  }
}
